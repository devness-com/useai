{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Daemon",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/packages/useai",
      "program": "${workspaceFolder}/packages/useai/dist/cli/index.js",
      "args": ["daemon-run"],
      "runtimeArgs": ["--watch"],
      "console": "integratedTerminal",
      "restart": true,
      "skipFiles": ["<node_internals>/**"],
      "preLaunchTask": "daemon:pre-debug",
      "outFiles": [
        "${workspaceFolder}/packages/*/dist/**/*.js"
      ],
      "sourceMaps": true
    },
    {
      "name": "Debug Dashboard",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["dev"],
      "cwd": "${workspaceFolder}/packages/dashboard",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}
